# Copy to .env and fill in. Only OPENAI_API_KEY is required.
OPENAI_API_KEY=sk-...

# Optional model / voice / persona
MODEL=gpt-realtime
VOICE=marin
INSTRUCTIONS=You are a helpful, concise voice assistant.

# WebSocket the device connects to
WS_HOST=0.0.0.0
WS_PORT=8765

# Home Assistant control (optional). Set both to enable the agent to act on the home.
# HA's MCP Server integration serves SSE here; create a long-lived token in HA.
HA_MCP_URL=http://YOUR_HA_IP:8123/mcp_server/sse
HA_TOKEN=
# Default Music Assistant media_player for "play music" when no speaker is named.
MUSIC_PLAYER=media_player.living_room
# HA weather entity the get_weather tool reads (default weather.forecast_home).
WEATHER_ENTITY=weather.forecast_home

# OpenAI server-side VAD tuning (defaults are sane)
VAD_THRESHOLD=0.5
VAD_PREFIX_PADDING_MS=300
# 800ms end-of-turn silence (OpenAI default 500 cut real questions at
# mid-sentence pauses with a TV on; costs ~0.3s response latency per turn).
VAD_SILENCE_DURATION_MS=800
# Adaptive VAD: raise the bar while the bot is speaking so its own echo doesn't
# chop replies; release delay covers the device's speaker buffer.
VAD_THRESHOLD_SPEAKING=0.85
VAD_RELEASE_DELAY_MS=1200

# Rotate the OpenAI session before its 60-min cap; refresh a stale idle session.
MAX_SESSION_SECONDS=3000
IDLE_REFRESH_SECONDS=600

# Dev only: bill an OpenAI Whisper transcription of each user turn and log what
# the model heard. Off by default (adds per-turn cost). Set to 1/true to enable.
DEBUG_TRANSCRIPTION=false
