# Copy to secrets.yaml and fill in. secrets.yaml is gitignored.
wifi_ssid: "YourWiFiSSID"          # 2.4 GHz only, the ESP32-S3 can't join 5 GHz
wifi_password: "YourWiFiPassword"
broker_url: "ws://YOUR_SERVER_IP:8765"   # where the broker listens (same LAN as the device)
# Used by Home Assistant to talk to the device (adopt it in HA with this key).
# Generate: python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
api_encryption_key: "GENERATE_A_32_BYTE_BASE64_KEY"
